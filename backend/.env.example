# LLM Configuration for What-If Analysis Tool
# Copy this file to .env and configure your settings

# ============================================================
# Local LLM (Default Configuration)
# ============================================================
# This is the default - uses Ollama with llama3 model
OPENAI_BASE_URL=http://localhost:4000/v1
OPENAI_MODEL=Qwen3-30B-A3B-Instruct-FP8
OPENAI_API_KEY=dummy-key

# ============================================================
# Other Local LLM Examples
# ============================================================
# vLLM (OpenAI-compatible server)
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_MODEL=llama-3-70b-instruct
# OPENAI_API_KEY=dummy-key

# Ollama (different model)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=mistral
# OPENAI_API_KEY=dummy-key

# ============================================================
# OpenAI API
# ============================================================
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
# OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================
# Azure OpenAI
# ============================================================
# OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# OPENAI_MODEL=gpt-4
# OPENAI_API_KEY=your-azure-api-key-here

# ============================================================
# Anthropic API
# ============================================================
# Uncomment to use Anthropic instead
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# LLM_TYPE=anthropic
